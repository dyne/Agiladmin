# Optional overrides for packaging/systemd/pocketbase.service.in
#
# Copy this file to:
#   @APP_HOME@/etc/pocketbase.env
# and adjust values as needed.

POCKETBASE_BIN=@APP_HOME@/bin/pocketbase
POCKETBASE_DIR=@APP_HOME@/var/pocketbase
POCKETBASE_HTTP=127.0.0.1:8090
POCKETBASE_MIGRATIONS_DIR=@APP_HOME@/pocketbase/migrations
