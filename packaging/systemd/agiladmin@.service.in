[Unit]
Description=Agiladmin payroll and project administration
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@APP_HOME@/%i
Environment=AGILADMIN_INSTANCE=%i
Environment=AGILADMIN_HOME=@APP_HOME@/%i
Environment=AGILADMIN_CONF=@APP_HOME@/%i/agiladmin.yaml
Environment=JAVA_OPTS=
ExecStart=/bin/sh -lc 'exec /usr/bin/java $$JAVA_OPTS -jar @APP_HOME@/lib/agiladmin.jar'
Restart=on-failure
RestartSec=5s
SyslogIdentifier=@APP_NAME@-%i
RuntimeDirectory=@APP_NAME@-%i
RuntimeDirectoryMode=0755
StateDirectory=@APP_NAME@-%i
StateDirectoryMode=0755

[Install]
WantedBy=multi-user.target
