appname: agiladmin

agiladmin:
  webserver:
    anti-forgery: false
    ssl-redirect: false
    port: 8000
    host: localhost

  budgets:
    git: ssh://git@example.org/admin-budgets
    ssh-key: @APP_HOME@/@INSTANCE@/id_rsa
    path: @APP_HOME@/@INSTANCE@/budgets/

  source:
    git: https://github.com/dyne/agiladmin
    update: false

  pocketbase:
    base-url: http://127.0.0.1:8090
    users-collection: users
    superuser-email: admin@example.org
    superuser-password: change-me
    connect-timeout-ms: 2000
    socket-timeout-ms: 2000
    manage-process: false
    binary: pocketbase
    dir: @APP_HOME@/var/pocketbase
    migrations-dir: @APP_HOME@/pocketbase/migrations
    version-file: @APP_HOME@/var/pocketbase/.agiladmin-version
